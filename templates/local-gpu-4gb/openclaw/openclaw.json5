// OpenClaw config - JSON5 format, human-maintained
// Primary: MiniMax-M2.7 | Fallback: Ollama → Gemini → NVIDIA
{
  // === PROVIDER: MiniMax PRIMARY (cloud) + Ollama LOCAL + Cloud Fallbacks ===
  models: {
    mode: "merge",
    providers: {
      // MiniMax - PRIMARY (Anthropic-compatible API)
      minimax: {
        baseUrl: "https://api.minimax.io/anthropic",
        apiKey: "env:MINIMAX_API_KEY",
        api: "anthropic-messages",
        models: [
          {
            id: "MiniMax-M2.7",
            name: "MiniMax-M2.7 (Primary)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 204800,
            maxTokens: 8192
          }
        ]
      },
      // Ollama - LOCAL PRIMARY FALLBACK
      ollama: {
        baseUrl: "http://127.0.0.1:11434",
        apiKey: "OLLAMA_API_KEY",
        api: "ollama",
        models: [
          {
            id: "phi4-mini:3.8b-q4_K_M",
            name: "Phi4-mini (Local, Tools)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192
          },
          {
            id: "aikid123/Qwen3-coder:latest",
            name: "Qwen3-coder (Fast + Thinking)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192
          },
          {
            id: "fredrezones55/Jan-code:Q4_K_M",
            name: "Jan-code (Daily)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192
          },
          {
            id: "fredrezones55/qwen3.5-opus:4b",
            name: "Qwen3.5-opus (Heavy Reasoning)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192
          },
          {
            id: "relational/orlex:latest",
            name: "Orlex (Planning)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192
          },
          {
            id: "rardiolata/CodeTito:latest",
            name: "CodeTito (Backup Coding)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192
          },
          {
            id: "softw8/Nanbeige4.1-3B-q4_K_M:latest",
            name: "Nanbeige4.1 (Tool Calling)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192
          },
          {
            id: "codegemma:2b",
            name: "CodeGemma (Autocomplete)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 8192,
            maxTokens: 8192
          },
          {
            id: "nomic-embed-text:latest",
            name: "Nomic Embed (Embeddings)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 2048,
            maxTokens: 8192
          }
        ]
      },
      // Google - CLOUD FALLBACK
      google: {
        baseUrl: "https://generativelanguage.googleapis.com/v1beta",
        apiKey: "env:GEMINI_API_KEY",
        api: "google-generative-ai",
        models: [
          {
            id: "gemini-2.5-flash",
            name: "Gemini 2.5 Flash (Free Tier)",
            reasoning: true,
            input: ["text", "image"],
            contextWindow: 1048576,
            maxTokens: 8192
          }
        ]
      },
      // NVIDIA - CLOUD FALLBACK
      nvidia: {
        baseUrl: "https://integrate.api.nvidia.com/v1",
        apiKey: "env:NVIDIA_API_KEY",
        api: "openai-completions",
        models: [
          {
            id: "meta/llama-3.3-70b-instruct",
            name: "Llama 3.3 70B (NVIDIA NIM)",
            reasoning: false,
            input: ["text"],
            contextWindow: 131072,
            maxTokens: 4096
          }
        ]
      }
    }
  },

  // === AGENT: MiniMax primary, Ollama fallback chain ===
  agents: {
    defaults: {
      model: {
        primary: "minimax/MiniMax-M2.7",
        fallbacks: [
          "ollama/phi4-mini:3.8b-q4_K_M",
          "ollama/aikid123/Qwen3-coder:latest",
          "ollama/fredrezones55/Jan-code:Q4_K_M",
          "ollama/fredrezones55/qwen3.5-opus:4b",
          "ollama/relational/orlex:latest",
          "ollama/rardiolata/CodeTito:latest",
          "ollama/softw8/Nanbeige4.1-3B-q4_K_M:latest",
          "google/gemini-2.5-flash",
          "nvidia/meta/llama-3.3-70b-instruct"
        ]
      },
      models: {
        "ollama/fredrezones55/Jan-code:Q4_K_M": {
          streaming: false
        }
      },
      workspace: "C:\\Users\\Alendia\\.openclaw\\workspace",
      contextPruning: {
        mode: "cache-ttl",
        ttl: "120m"
      },
      compaction: {
        mode: "default",
        reserveTokensFloor: 8000,
        timeoutSeconds: 120
      },
      blockStreamingDefault: "off",
      heartbeat: {
        every: "60m"
      },
      subagents: {
        maxConcurrent: 1,
        runTimeoutSeconds: 120
      }
    },
    list: [
      {
        id: "main",
        default: true,
        name: "MiniMax-M2.7",
        model: {
          primary: "minimax/MiniMax-M2.7",
          fallbacks: [
            "ollama/phi4-mini:3.8b-q4_K_M",
            "ollama/aikid123/Qwen3-coder:latest",
            "ollama/fredrezones55/Jan-code:Q4_K_M",
            "ollama/fredrezones55/qwen3.5-opus:4b",
            "ollama/relational/orlex:latest",
            "ollama/rardiolata/CodeTito:latest",
            "ollama/softw8/Nanbeige4.1-3B-q4_K_M:latest",
            "google/gemini-2.5-flash",
            "nvidia/meta/llama-3.3-70b-instruct"
          ]
        },
        identity: {
          name: "MiniMax-M2.7"
        }
      },
      {
        id: "tcall",
        name: "Phi4-tcall",
        model: {
          primary: "ollama/phi4-mini:3.8b-q4_K_M",
          fallbacks: [
            "ollama/softw8/Nanbeige4.1-3B-q4_K_M:latest",
            "google/gemini-2.5-flash",
            "nvidia/meta/llama-3.3-70b-instruct"
          ]
        },
        identity: {
          name: "Phi4-tcall"
        }
      }
    ]
  },

  // === TOOLS ===
  tools: {
    profile: "coding",
    web: {
      search: { timeoutSeconds: 15 },
      fetch: { timeoutSeconds: 15 }
    },
    loopDetection: {
      enabled: true,
      warningThreshold: 5,
      criticalThreshold: 10
    },
    exec: {
      backgroundMs: 5000,
      timeoutSec: 120
    }
  },

  // === BINDINGS ===
  bindings: [
    { agentId: "main", match: { channel: "telegram", accountId: "default" } }
  ],

  // === MESSAGES ===
  messages: {
    responsePrefix: "",
    queue: { mode: "steer", debounceMs: 1500, cap: 10 },
    inbound: { debounceMs: 1500 }
  },

  // === COMMANDS ===
  commands: {
    native: "auto",
    nativeSkills: "auto",
    restart: true,
    ownerDisplay: "raw"
  },

  // === SESSION ===
  session: {
    dmScope: "per-channel-peer",
    maintenance: {
      mode: "enforce",
      pruneAfter: "14d",
      maxEntries: 200,
      rotateBytes: "5mb"
    }
  },

  // === CHANNELS: Telegram ===
  channels: {
    telegram: {
      enabled: true,
      dmPolicy: "pairing",
      botToken: "env:TELEGRAM_BOT_TOKEN",
      groupPolicy: "allowlist",
      streaming: "off"
    }
  },

  // === GATEWAY ===
  gateway: {
    port: 18789,
    mode: "local",
    bind: "loopback",
    auth: {
      mode: "token",
      token: "env:OPENCLAW_GATEWAY_TOKEN"
    },
    tailscale: {
      mode: "off",
      resetOnExit: false
    }
  },

  // === SKILLS ===
  skills: {
    install: {
      nodeManager: "npm"
    }
  },

  // === PLUGINS ===
  plugins: {
    entries: {
      ollama: {
        enabled: true,
        config: {}
      }
    }
  }
}
