// OpenClaw config - JSON5 format, human-maintained
{
  // === PROVIDER: Ollama LOCAL ONLY (Phase 1-5) ===
  models: {
    providers: {
      ollama: {
        baseUrl: "http://127.0.0.1:11434/v1",
        apiKey: "ollama-local",
        api: "openai-completions", // PENTING: bukan "openai-responses" untuk Ollama
        models: [
          {
            id: "fredrezones55/Jan-code:Q4_K_M",
            name: "Jan-code (Daily Default)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 4096
          },
          {
            id: "aikid123/Qwen3-coder:latest",
            name: "Qwen3-coder (Fast + Thinking)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 4096
          },
          {
            id: "fredrezones55/qwen3.5-opus:4b",
            name: "Qwen3.5-opus (Heavy Reasoning)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 4096
          },
          {
            id: "relational/orlex:latest",
            name: "Orlex (Backup Planning)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 4096
          },
          {
            id: "rardiolata/CodeTito:latest",
            name: "CodeTito (Backup Coding)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 4096
          }
        ]
      }
    }
    // Cloud providers: Phase 6, commented out, default OFF
    // See plan 001 Phase 6 for details
  },

  // === AGENT: Local auto-swap fallback chain ===
  agents: {
    defaults: {
      model: {
        primary: "ollama/fredrezones55/Jan-code:Q4_K_M",
        fallbacks: [
          "ollama/aikid123/Qwen3-coder:latest",
          "ollama/fredrezones55/qwen3.5-opus:4b",
          "ollama/relational/orlex:latest",
          "ollama/rardiolata/CodeTito:latest"
        ]
      },
      models: {
        // Disable streaming jika tool calls bermasalah
        "ollama/fredrezones55/Jan-code:Q4_K_M": {
          streaming: false
        }
      },
      // Context pruning: 120m reduces background CPU cycles on work PCs
      // (30m default causes frequent background timer activity even when idle)
      contextPruning: {
        mode: "cache-ttl",
        ttl: "120m"
      },
      heartbeat: {
        every: "60m"
      }
    }
  },

  // === GATEWAY ===
  gateway: {
    port: 18789,
    auth: { mode: "password" }
  },

  // === CHANNELS: Telegram only (Phase 2) ===
  channels: {
    telegram: {
      dmPolicy: "pairing" // unknown sender = pairing code dulu
    }
  }
}
